# Docker Configuration
COMPOSE_PROJECT_NAME=incalake

# Backend Ports
BACKEND_PORT=8001
NGINX_PORT=80
NGINX_SSL_PORT=443

# Frontend Ports
FRONTEND_PORT=3001
ADMIN_PORT=54112

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=incalake_tours
DB_USERNAME=incalake
DB_PASSWORD=secret

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# phpMyAdmin Port
PHPMYADMIN_PORT=8080

# Mailhog Ports
MAILHOG_PORT=1025
MAILHOG_WEB_PORT=8025